# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=replace-with-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-strong-password

# Platform API keys: "platform_id:key" pairs, comma-separated
# Generate keys with: python -c "import secrets; print(secrets.token_urlsafe(32))"
PLATFORM_API_KEYS=pyrates:YOUR_PYRATES_KEY,algopython:YOUR_ALGOPYTHON_KEY

# ── AI Model API Keys ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
MISTRAL_API_KEY=...
GOOGLE_API_KEY=...   # For Gemini 2.0 Flash + Imagen 3

# ── Model selection (optional — defaults shown) ───────────────────────────────
ORCHESTRATOR_MODEL=claude-sonnet-4-6
MISTRAL_MODEL=mistral-large-latest
GEMINI_MODEL=gemini-2.5-pro
NANO_BANANA_MODEL=gemini-2.5-flash-image
IMAGE_MAX_ITERATIONS=3
TEXT_MAX_ITERATIONS=3   # Max orchestrator-driven regeneration attempts per text component

# ── Storage ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://feedback:feedback@localhost:5432/feedback
CHROMA_PERSIST_DIR=./data/chroma
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2

# ── AlgoPython source database (read-only, MySQL) ────────────────────────────
# This is your AlgoPython production database. The system reads exercises,
# errors, and task types from it — it never writes to it.
# Format: mysql+aiomysql://USER:PASSWORD@HOST:3306/DBNAME
# Leave empty to disable (feedback will fall back to the local catalog only).
ALGOPYTHON_DATABASE_URL=mysql+aiomysql://USER:PASSWORD@HOST:3306/DBNAME
